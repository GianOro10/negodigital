{
  "name": "negodigital",
  "version": "1.0.0",
  "description": "Plataforma para descubrir negocios sin presencia digital y crearles su página web",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "build": "cd frontend && npm run build",
    "start": "cd backend && npm start",
    "seed": "cd backend && npm run seed",
    "test": "cd backend && npm test"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GianOro10/negodigital.git"
  },
  "keywords": ["negocios", "digitalización", "web", "marketplace", "pymes"],
  "author": "GianOro10",
  "license": "MIT"
}
